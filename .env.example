APP_NAME=Gate.io Capital Preservation Bot
ENVIRONMENT=local
SECRET_KEY=change-me
# ── Railway deployment ─────────────────────────────────────────
# Railway auto-provisions DATABASE_URL and REDIS_URL when you attach
# Postgres + Redis plugins. The _normalize_database_url validator
# handles Railway's postgres:// scheme automatically.
# Required vars to set in Railway dashboard (Shared Variables):
#   ENVIRONMENT=production
#   SECRET_KEY=<random-64-char>
#   FERNET_KEY=<generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">
#   CORS_ORIGINS=https://<frontend-domain>.up.railway.app
#   BACKEND_URL=http://backend.railway.internal:8000  (internal networking)
# Build arg for frontend service:
#   NEXT_PUBLIC_API_URL=https://<backend-domain>.up.railway.app
# ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://gatebot:gatebot@postgres:5432/gatebot
REDIS_URL=redis://redis:6379/0
POSTGRES_PASSWORD=gatebot

# Next.js rewrite proxy target (internal service name for Railway)
BACKEND_URL=http://backend:8000

GATEIO_API_KEY=
GATEIO_API_SECRET=
GATEIO_BASE_URL=https://api.gateio.ws/api/v4
GATEIO_REQUESTS_PER_SECOND=5
GATEIO_WS_URL=wss://api.gateio.ws/ws/v4/

FERNET_KEY=
# Short-lived access tokens; role changes / revocation propagate within this window.
ACCESS_TOKEN_EXPIRE_MINUTES=15
# Long-lived but server-tracked, individually revocable refresh tokens.
REFRESH_TOKEN_EXPIRE_DAYS=7
# Brute-force protection on /auth/login.
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
# Comma-separated allowed CORS origins for the dashboard.
# Railway: set to your frontend domain, e.g. https://frontend.up.railway.app
CORS_ORIGINS=http://localhost:3000

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

BOT_ENABLED=false
# Go-live gate: require the live strategy to have PASSED a recent walk-forward
# validation (on the live timeframe) before it opens new trades. Blocks new
# entries until a passing, fresh run exists (open positions are still managed).
# Disable only if you validate strategies out-of-band.
LIVE_REQUIRE_WALKFORWARD=true
LIVE_VALIDATION_MAX_AGE_DAYS=90
DEFAULT_QUOTE_CURRENCY=USDT
# Stablecoins counted as cash at par in equity (not marked to market).
STABLECOINS=USDT,USDC,DAI,TUSD,FDUSD

# Opportunity cost of idle capital (idle-USDT lending/Earn yield); the strategy
# must beat this hurdle to add value.
ANNUAL_RISK_FREE_RATE=0.04

# Graded de-risking: shrink position size as account drawdown approaches the
# max (recovery-math aware), before the circuit breaker hard-stops.
DRAWDOWN_DERISK_ENABLED=true
DRAWDOWN_DERISK_FLOOR=0.0

# Stablecoin (quote) depeg monitoring: pause new entries if the reference
# stablecoin pair drifts beyond the threshold from parity (1.0).
QUOTE_DEPEG_REFERENCE_PAIR=USDC_USDT
QUOTE_DEPEG_THRESHOLD_PCT=0.01
QUOTE_DEPEG_HALT=true

# Volatility targeting (opt-in): scale position size inversely to ATR so
# per-trade risk stays steadier. Disabled by default.
VOL_TARGETING_ENABLED=false
VOL_TARGET_ATR_PCT=0.02
VOL_TARGET_MIN_MULTIPLIER=0.25
VOL_TARGET_MAX_MULTIPLIER=2.0

# --- Live strategy entry thresholds (tunable per market) ---
STRATEGY_RSI_THRESHOLD=45
STRATEGY_EMA20_DISTANCE_PCT=0.02
# Max 24h range vs price before rejecting an entry (0.12 allows normal crypto vol).
STRATEGY_MAX_24H_RANGE_PCT=0.12
# Default trailing-stop distance (overridden by DB StrategySettings when set).
STRATEGY_TRAILING_STOP_PCT=0.01
# Number of candles that represent a "daily" range (depends on candle interval).
STRATEGY_DAILY_RANGE_CANDLES=24
# Min volume ratio: allow entries at 30% of average (was 50%).
STRATEGY_MIN_VOLUME_RATIO=0.3
TRADING_SYMBOLS=BTC_USDT,ETH_USDT,XRP_USDT,DOGE_USDT,SOL_USDT,ADA_USDT,LINK_USDT,AVAX_USDT

# --- Paper trading settings ---
# Mirror live: paper adopts the LIVE account's economics (timeframe, market/
# direction/leverage, fees, funding, risk sizing & limits) so paper results track
# real trading — no surprises at go-live. Turn OFF to run paper on its paper_* knobs.
PAPER_MIRROR_LIVE=true
# Your Gate.io SPOT fee tier (used when mirroring a spot live account). Base tier
# ~0.2% (0.002); ~0.1% (0.001) with a GT deduction. Set to what you actually pay.
# Default is the conservative base tier (0.002) — assuming the cheaper tier makes
# paper look more profitable than live.
PAPER_SPOT_TAKER_FEE=0.002
PAPER_SPOT_MAKER_FEE=0.002
PAPER_RSI_THRESHOLD=35
PAPER_EMA20_DISTANCE_PCT=0.015
PAPER_TREND_FILTER_ENABLED=true
PAPER_EVAL_INTERVAL_SECONDS=30
PAPER_ORDER_TYPE=market
STRATEGY_RSI_OVERBOUGHT=65
STRATEGY_MTF_ENABLED=true
STRATEGY_MTF_INTERVAL=4h
# Regime-aware strategy routing (live + paper). When true, the bot picks the
# strategy best suited to the CURRENT regime per symbol — momentum in
# trends/breakouts, mean-reversion in ranges — instead of forcing one strategy
# through every regime. Off by default (trades exactly LIVE_STRATEGY/PAPER_STRATEGY).
REGIME_ROUTING_ENABLED=false
# Funding carry as ALPHA (futures only). When true, an entry whose direction
# COLLECTS funding (long while funding<0 / short while funding>0) is sized UP to
# harvest that recurring cash flow — capped, and the gross-exposure clamp still
# bounds total risk. Adverse funding is still de-risked (FUNDING_SIGNAL_*).
FUNDING_CARRY_ENABLED=false
FUNDING_CARRY_THRESHOLD_PCT=0.0005
FUNDING_CARRY_MAX_MULT=1.25
# Partial profit taking (scale-out). When true, close SCALE_OUT_FRACTION of a
# position once it reaches SCALE_OUT_R_MULTIPLE of profit (in units of the entry
# risk R), move the stop to breakeven, and ride the remainder risk-free via
# trailing. Banks profit and de-risks without capping the runner. Off by default.
SCALE_OUT_ENABLED=false
SCALE_OUT_R_MULTIPLE=1.0
SCALE_OUT_FRACTION=0.5
MOVE_TO_BREAKEVEN_ON_SCALE_OUT=true

# Equity used when the exchange balance cannot be fetched (no keys / offline).
FALLBACK_EQUITY=10000
# Account drawdown from peak equity that trips the circuit breaker.
MAX_ACCOUNT_DRAWDOWN_PCT=0.15
# Max age (seconds) of an equity snapshot before new entries are skipped.
MAX_EQUITY_STALENESS_SECONDS=1800
MARKET_DATA_INTERVAL=15m
# How often the LIVE scheduler scans for entries + ingests candles (minutes).
# Track this to your trading timeframe: a fast momentum/breakout strategy on 5m
# needs a 5-minute scan to act on the breakout bar — a fixed 15m scan lags a full
# bar and misses the move. Default 15 (legacy capital-preservation cadence).
LIVE_ENTRY_INTERVAL_MINUTES=15

# --- Live worker watchdog ---
# The API process watches the live scheduler's heartbeat and alerts (Telegram +
# log) if it goes silent — so a crashed/stuck worker that would leave open
# positions unmanaged is surfaced. Enable this ONLY on the LIVE deployment
# (paper-only deployments have no scheduler and would alarm forever).
WORKER_WATCHDOG_ENABLED=false
WORKER_WATCHDOG_CHECK_SECONDS=300
# Heartbeat older than this (s) => worker treated as dead. ~3 missed 15m cycles.
WORKER_HEARTBEAT_STALE_SECONDS=2700

# --- Market Data Quality ---
MDQ_SPIKE_THRESHOLD_PCT=0.10
MDQ_ZSCORE_THRESHOLD=5.0
MDQ_VOLUME_SPIKE_MULTIPLE=8.0
MDQ_LIQUIDITY_DROP_PCT=0.10
MDQ_CROSS_EXCHANGE_THRESHOLD_PCT=0.01
# Spike handling: flag | smooth | ignore
MDQ_SPIKE_MODE=flag
MDQ_PAUSE_ON_INVALID=true
MDQ_ENABLE_ML=true
# Position-size multiplier while the data feed is DEGRADED.
MDQ_DEGRADED_RISK_MULTIPLIER=0.5

# --- Strategy Research Lab ---
# Production promotion gate.
RESEARCH_MIN_SHARPE=1.0
RESEARCH_MAX_DRAWDOWN=0.20
RESEARCH_MIN_STABILITY=0.5
RESEARCH_MIN_CONSISTENCY=0.5
RESEARCH_MIN_TRADES=20
RESEARCH_WF_WINDOWS=4
RESEARCH_POPULATION=12
RESEARCH_SURVIVORS=4

# --- Auto Learning & Continuous Evolution ---
LEARNING_ENABLED=true
LEARNING_POPULATION=8
# Promotion gate (human approval still required afterwards).
LEARNING_GATE_MIN_SHARPE=1.5
LEARNING_GATE_MIN_PROFIT_FACTOR=1.3
LEARNING_GATE_MIN_CONSISTENCY=0.60
LEARNING_GATE_MAX_RUIN=0.20
LEARNING_MIN_RANKING=60.0

# --- Portfolio ---
PORTFOLIO_REBALANCE_DRAWDOWN_PCT=0.05
PORTFOLIO_REBALANCE_WEEKLY_DAYS=7
PORTFOLIO_REBALANCE_MONTHLY_DAYS=30
PORTFOLIO_CORRELATION_THRESHOLD=0.8
PORTFOLIO_CORRELATION_LIMIT=500
# Stress test shock magnitudes.
STRESS_MARKET_CRASH_PCT=0.30
STRESS_FLASH_CRASH_MAJOR=0.50
STRESS_FLASH_CRASH_ALT=0.70
STRESS_HIGH_VOL_PCT=0.15
STRESS_CORRELATION_SPIKE_PCT=0.20

# --- Backtest ---
BACKTEST_MONTE_CARLO_SCENARIOS=1000

# --- Strategy Health Risk Adjuster ---
HEALTH_DRIFT_TIER_LOW=0.3
HEALTH_DRIFT_TIER_MID=0.5
HEALTH_DRIFT_TIER_HIGH=0.7
HEALTH_RISK_MULT_LOW=1.0
HEALTH_RISK_MULT_MID=0.7
HEALTH_RISK_MULT_HIGH=0.4
HEALTH_RISK_MULT_PAUSED=0.0

# --- Execution Quality ---
EQ_DEFAULT_VOLATILITY=0.015
EQ_DEFAULT_SPREAD=0.0002
EQ_LATENCY_ZSCORE_THRESHOLD=3.0
EQ_CRITICAL_SLIPPAGE_PCT=0.005
EQ_PARTIAL_FILL_EXPLOSION_THRESHOLD=4

# --- Portfolio Allocator ---
ALLOC_WEIGHT_STRATEGY=0.40
ALLOC_WEIGHT_RISK_ADJ=0.30
ALLOC_WEIGHT_CORRELATION=0.20
ALLOC_WEIGHT_STABILITY=0.10
ALLOC_DD_TIER_HIGH=0.15
ALLOC_DD_TIER_MID=0.08
ALLOC_DD_TIER_LOW=0.03
ALLOC_DD_SCALE_HIGH=0.30
ALLOC_DD_SCALE_MID=0.60
ALLOC_DD_SCALE_LOW=0.85
