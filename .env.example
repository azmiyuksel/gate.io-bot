APP_NAME=Gate.io Capital Preservation Bot
ENVIRONMENT=local
SECRET_KEY=change-me
DATABASE_URL=postgresql+psycopg://gatebot:gatebot@postgres:5432/gatebot
REDIS_URL=redis://redis:6379/0

GATEIO_API_KEY=
GATEIO_API_SECRET=
GATEIO_BASE_URL=https://api.gateio.ws/api/v4
GATEIO_REQUESTS_PER_SECOND=5
GATEIO_WS_URL=wss://api.gateio.ws/ws/v4/

FERNET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

BOT_ENABLED=false
DEFAULT_QUOTE_CURRENCY=USDT
TRADING_SYMBOLS=BTC_USDT,ETH_USDT

# Equity used when the exchange balance cannot be fetched (no keys / offline).
FALLBACK_EQUITY=10000
# Account drawdown from peak equity that trips the circuit breaker.
MAX_ACCOUNT_DRAWDOWN_PCT=0.15
# Max age (seconds) of an equity snapshot before new entries are skipped.
MAX_EQUITY_STALENESS_SECONDS=1800
MARKET_DATA_INTERVAL=1h

# --- Market Data Quality ---
MDQ_SPIKE_THRESHOLD_PCT=0.10
MDQ_ZSCORE_THRESHOLD=5.0
MDQ_VOLUME_SPIKE_MULTIPLE=8.0
MDQ_LIQUIDITY_DROP_PCT=0.10
MDQ_CROSS_EXCHANGE_THRESHOLD_PCT=0.01
# Spike handling: flag | smooth | ignore
MDQ_SPIKE_MODE=flag
MDQ_PAUSE_ON_INVALID=true
MDQ_ENABLE_ML=true

# --- Strategy Research Lab ---
# Production promotion gate.
RESEARCH_MIN_SHARPE=1.0
RESEARCH_MAX_DRAWDOWN=0.20
RESEARCH_MIN_STABILITY=0.5
RESEARCH_MIN_CONSISTENCY=0.5
RESEARCH_MIN_TRADES=20
RESEARCH_WF_WINDOWS=4
RESEARCH_POPULATION=12
RESEARCH_SURVIVORS=4

# --- Auto Learning & Continuous Evolution ---
LEARNING_ENABLED=true
LEARNING_POPULATION=8
# Promotion gate (human approval still required afterwards).
LEARNING_GATE_MIN_SHARPE=1.5
LEARNING_GATE_MIN_PROFIT_FACTOR=1.3
LEARNING_GATE_MIN_CONSISTENCY=0.60
LEARNING_GATE_MAX_RUIN=0.20
LEARNING_MIN_RANKING=60.0
